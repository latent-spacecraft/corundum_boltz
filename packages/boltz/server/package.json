{
  "name": "corundum-blobber",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker + RDKit container for ligand SMILES → Boltz blob preprocessing",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "docker:build": "docker build -f Dockerfile -t corundum-blobber ..",
    "docker:run": "docker run --rm -p 8080:8080 corundum-blobber"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.40"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
